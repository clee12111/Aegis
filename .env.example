# Meridian — .env for the Act II exploit gate
# Only the generation key is needed; the direct Phase 8/10 exploit path bypasses retrieval.

# REQUIRED — generation model (DeepSeek deepseek-v4-flash; used by Phases 3 / 8 / 10)
DEEPSEEK_API_KEY=your-deepseek-key-here

# NOT NEEDED for the exploit path (retrieval / legacy plumbing) — leave unset:
# VOYAGE_API_KEY=        # embeddings (retrieval only)
# QDRANT_URL=            # vector DB (retrieval only)
# QDRANT_API_KEY=        # vector DB auth (retrieval only)
# OPENAI_API_KEY=        # legacy (MAUD title-gen / paper replication only)
# LANGFUSE_PUBLIC_KEY=   # tracing (not wired)
# LANGFUSE_SECRET_KEY=
# PHOENIX_ENABLED=false